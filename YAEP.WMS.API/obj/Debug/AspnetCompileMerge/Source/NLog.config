<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      throwExceptions = "false"
      autoReload="true"
      autoFlush="false"
      >
  <targets>
    <target name="csv" xsi:type="File" fileName="${basedir}/logs/${shortdate}.csv" 
            keepFileOpen="true" openFileCacheTimeout="30" concurrentWrites="false" OpenFileFlushTimeout="1">
      <layout xsi:type="CSVLayout">
        <column name="Level" layout="${event-properties:item=Level}" />
        <column name="Content" layout="${event-properties:item=Content}" />
        <column name="ExceptionMessage" layout="$${event-properties:item=ExceptionMessage}" />
        <column name="ExceptionStackTrace" layout="${event-properties:item=ExceptionStackTrace}" />
        <column name="MachineName" layout="${event-properties:item=MachineName}" />
        <column name="Source" layout="${event-properties:item=Source}" />
        <column name="ThreadId" layout="${event-properties:item=ThreadId}" />
        <column name="Type" layout="${event-properties:item=Type}" />
        <column name="Logger" layout="${event-properties:item=Logger}" />
        <column name="IP" layout="${event-properties:item=IP}" />
        <column name="Application" layout="${event-properties:item=Application}" />
        <column name="SubApplication" layout="${event-properties:item=SubApplication}" />
        <column name="Alias" layout="${event-properties:item=Alias}" />
        <column name="BelongToType" layout="${event-properties:item=BelongToType}" />
        <column name="BelongToUID" layout="${event-properties:item=BelongToUID}" />
        <column name="BelongToRemark" layout="${event-properties:item=BelongToRemark}" />
        <column name="ObjectBefore" layout="${event-properties:item=ObjectBefore}" />
        <column name="ObjectAfter" layout="${event-properties:item=ObjectAfter}" />

      </layout>
    </target>
  </targets>
  <rules>
    <logger name="*" level="Trace" writeTo="csv" />
    <logger name="*" level="Info" writeTo="csv" />
    <logger name="*" level="Error" writeTo="csv" />
    <logger name="*" level="Debug" writeTo="csv" />
  </rules>
</nlog>
