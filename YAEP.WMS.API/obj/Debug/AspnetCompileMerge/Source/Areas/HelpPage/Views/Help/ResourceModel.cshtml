@using System.Web.Http
@using YAEP.WMS.Api.Areas.HelpPage.ModelDescriptions
@model ModelDescription

<link type="text/css" href="~/Areas/HelpPage/HelpPage.css?ver=@DateTime.Now.ToString("yyyyMMdd")" rel="stylesheet" />
<div id="body" class="help-page">
    <section class="featured">
        <div class="content-wrapper">
            <p>
                [<b>@Html.ActionLink("Help Page Home", "Index")</b>]
            </p>
        </div>
    </section>
    <p>&nbsp;</p>
    <fieldset>
        <legend class="legendB">
            @Model.Name
        </legend>
        <p>@Model.Documentation</p>
        <section class="content-wrapper main-content clear-fix">
            @Html.DisplayFor(m => Model)
        </section>
    </fieldset>
</div>
