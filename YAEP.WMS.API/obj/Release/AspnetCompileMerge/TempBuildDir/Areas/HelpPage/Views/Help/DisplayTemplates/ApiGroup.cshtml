@using System.Web.Http
@using System.Web.Http.Controllers
@using System.Web.Http.Description
@using YAEP.WMS.Api.Areas.HelpPage
@using YAEP.WMS.Api.Areas.HelpPage.Models
@model IGrouping<HttpControllerDescriptor, ApiDescription>

@{
    var controllerDocumentation = ViewBag.DocumentationProvider != null ?
        ViewBag.DocumentationProvider.GetDocumentation(Model.Key) :
        "None";
}

<br />
<p>

    <fieldset>
        <legend class="legendB" onclick="c('content_@Model.Key.ControllerName')">
            @Model.Key.ControllerName
        </legend>
        <div id="content_@Model.Key.ControllerName">
@{
    if (!String.IsNullOrEmpty(controllerDocumentation))
    {
        <p>@controllerDocumentation</p> 
    }
    else
    {
        <p>No documentation available</p> 
    }
}

            <table class="help-page-table">
                <thead>
                    <tr><th>API</th><th>Description</th></tr>
                </thead>
                <tbody>
                    @foreach (var api in Model)
                    {
                        <tr>
                            <td class="api-name"><div class="api-method-@api.HttpMethod.Method">@api.HttpMethod.Method</div>&nbsp;&nbsp;<a href="@Url.Action("Api", "Help", new { apiId = api.GetFriendlyId() })"><div style="display: inline-block;width:90%">@api.RelativePath</div></a></td>
                            <td class="api-documentation">
                                @if (api.Documentation != null)
                                {
                                    <p>@api.Documentation</p>
                                }
                                else
                                {
                                    <p>No documentation available.</p>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
            </fieldset>
            </p>
